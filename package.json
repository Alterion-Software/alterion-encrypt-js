{
  "name": "alterion-encrypt",
  "version": "1.0.0",
  "description": "X25519 ECDH key exchange, AES-256-GCM session encryption, and a MessagePack + Deflate request/response pipeline — framework-agnostic client-side counterpart to the alterion-encrypt Rust crate.",
  "license": "GPL-3.0",
  "author": "Alterion Software",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alterion-Software/alterion-encrypt-js"
  },
  "type": "module",
  "main":    "./dist/index.cjs",
  "module":  "./dist/index.js",
  "types":   "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev":   "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@noble/ciphers":   "^2.1.0",
    "@noble/curves":    "^2.0.0",
    "@noble/hashes":    "^2.0.0"
  },
  "devDependencies": {
    "tsup":       "^8.0.0",
    "typescript": "~5.9.0"
  }
}
